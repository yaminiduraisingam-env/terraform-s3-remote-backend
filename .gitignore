# Terragrunt cache — generated at runtime, never commit
**/.terragrunt-cache/

# OpenTofu working directories — generated at runtime
**/.terraform/
**/.terraform.lock.hcl

# Generated backend and provider files — Terragrunt creates these at runtime
**/backend.tf
**/provider.tf

# State files — state lives in S3, not in git
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# macOS
.DS_Store

# IDE
.idea/
.vscode/
